{
  "name": "voice-draw-ai",
  "version": "1.0.0",
  "private": true,
  "description": "AI 语音绘图工具",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=web\"",
    "build": "npm run build --workspace=@voice-draw/shared && npm run build --workspace=server && npm run build --workspace=web",
    "build:shared": "npm run build --workspace=@voice-draw/shared",
    "build:server": "npm run build --workspace=server",
    "build:web": "npm run build --workspace=web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "@types/express": "4.17.21"
  }
}
