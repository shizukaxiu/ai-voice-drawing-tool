PORT=8080

# 讯飞开放平台 — 语音听写（流式版）WebAPI
IFLYTEK_APP_ID=your_app_id
IFLYTEK_API_KEY=your_api_key
IFLYTEK_API_SECRET=your_api_secret

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key

# 图像服务提供商：dashscope（通义万相）或 siliconflow（硅基流动）
IMAGE_PROVIDER=siliconflow

# 阿里云百炼 / 通义万相（IMAGE_PROVIDER=dashscope 时必填）
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_IMAGE_MODEL=wanx2.1-t2i-turbo

# 硅基流动（IMAGE_PROVIDER=siliconflow 时必填）
SILICONFLOW_API_KEY=your_siliconflow_api_key
SILICONFLOW_IMAGE_MODEL=Qwen/Qwen-Image-Edit-2509
